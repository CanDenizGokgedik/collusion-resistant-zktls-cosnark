erify(bytes32,uint256,uint256,uint256,uint256)":"a1f31281","verifyAttestation((bytes32,bytes32,bytes32,uint256,uint256,uint256,uint256,uint8,uint8))":"959bb7a2","verifyRaw(bytes)":"457726e6"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.24+commit.e11b9ed9\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"constructor\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"statementDigest\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"bytes32\",\"name\":\"randValue\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"uint8\",\"name\":\"threshold\",\"type\":\"uint8\"}],\"name\":\"AttestationAccepted\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"statementDigest\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"string\",\"name\":\"reason\",\"type\":\"string\"}],\"name\":\"AttestationRejected\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"uint256\",\"name\":\"keyX\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"keyY\",\"type\":\"uint256\"}],\"name\":\"GroupKeyAuthorized\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"uint256\",\"name\":\"keyX\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"keyY\",\"type\":\"uint256\"}],\"name\":\"GroupKeyRevoked\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"keyX\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"keyY\",\"type\":\"uint256\"}],\"name\":\"authorizeGroupKey\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"name\":\"authorizedGroupKeys\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"keyX\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"keyY\",\"type\":\"uint256\"}],\"name\":\"isGroupKeyAuthorized\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"owner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"keyX\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"keyY\",\"type\":\"uint256\"}],\"name\":\"revokeGroupKey\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"message_hash\",\"type\":\"bytes32\"},{\"internalType\":\"uint256\",\"name\":\"pk_x\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"pk_y\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sig_R_x\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sig_s\",\"type\":\"uint256\"}],\"name\":\"verify\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"components\":[{\"internalType\":\"bytes32\",\"name\":\"statementDigest\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"dvrf_value\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"envelopeDigest\",\"type\":\"bytes32\"},{\"internalType\":\"uint256\",\"name\":\"groupKeyX\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"groupKeyY\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sigRX\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sigS\",\"type\":\"uint256\"},{\"internalType\":\"uint8\",\"name\":\"threshold\",\"type\":\"uint8\"},{\"internalType\":\"uint8\",\"name\":\"verifierCount\",\"type\":\"uint8\"}],\"internalType\":\"struct TLSAttestation.Attestation\",\"name\":\"att\",\"type\":\"tuple\"}],\"name\":\"verifyAttestation\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes\",\"name\":\"raw\",\"type\":\"bytes\"}],\"name\":\"verifyRaw\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"custom:changes\":\"- verifyAttestation: external \\u2192 public (child contracts call it directly).   - verifyAttestation: added threshold == 0 guard.   - verifyAttestation: added authorized group key registry check.   - verifyRaw: removed `this.` prefix.   - authorizeGroupKey / revokeGroupKey: owner-controlled key registry.\",\"details\":\"Group key registry (fix for \\\"group key not validated on-chain\\\"):   Without a registry, any party can run their own DKG ceremony and produce   a valid FROST signature over an arbitrary statement, then submit it as a   TLS attestation.  The signature math is correct, but the group key has no   connection to the intended verifier quorum.   The fix introduces an `authorizedGroupKeys` mapping.  Only keys registered   by the contract owner (e.g. via governance or a multisig) are accepted.   DKG ceremony coordinators must call `authorizeGroupKey` after a successful   key ceremony; participants verify their own output before signing.\",\"kind\":\"dev\",\"methods\":{\"authorizeGroupKey(uint256,uint256)\":{\"details\":\"Call this after a successful DKG ceremony.  Only the owner may      authorize keys, preventing rogue DKG substitution attacks.\"},\"verify(bytes32,uint256,uint256,uint256,uint256)\":{\"params\":{\"message_hash\":\"32-byte digest that was signed (envelope_digest).\",\"pk_x\":\"x-coordinate of the group verifying key.\",\"pk_y\":\"y-coordinate of the group verifying key.\",\"sig_R_x\":\"x-coordinate of the nonce commitment R (even-y convention).\",\"sig_s\":\"Schnorr scalar s.\"},\"returns\":{\"valid\":\"       true iff the signature is valid.\"}}},\"stateVariables\":{\"authorizedGroupKeys\":{\"details\":\"Authorized group public keys: keccak256(abi.encodePacked(x, y)) \\u2192 true. Using a hash avoids storing two uint256 words per key.\"}},\"title\":\"TLSAttestation\",\"version\":1},\"userdoc\":{\"events\":{\"GroupKeyAuthorized(uint256,uint256)\":{\"notice\":\"Emitted when a group key is added to the authorized registry.\"},\"GroupKeyRevoked(uint256,uint256)\":{\"notice\":\"Emitted when a group key is removed from the registry.\"}},\"kind\":\"user\",\"methods\":{\"authorizeGroupKey(uint256,uint256)\":{\"notice\":\"Register an authorized DKG group key.\"},\"isGroupKeyAuthorized(uint256,uint256)\":{\"notice\":\"Check whether a group key is currently authorized.\"},\"revokeGroupKey(uint256,uint256)\":{\"notice\":\"Revoke an authorized group key (e.g. after a key rotation).\"},\"verify(bytes32,uint256,uint256,uint256,uint256)\":{\"notice\":\"Verify a FROST Schnorr aggregate signature.\"},\"verifyAttestation((bytes32,bytes32,bytes32,uint256,uint256,uint256,uint256,uint8,uint8))\":{\"notice\":\"SC.Verify(\\u03c3, pk) \\u2014 Verify a \\u03a0_coll-min attestation. Checks (in order):   1. statementDigest is non-zero.   2. threshold is at least 1.   3. threshold \\u2264 verifierCount.   4. Group key is in the authorized registry.  [new]   5. FROST Schnorr signature is valid.\"}},\"notice\":\"On-chain attestation verifier for \\u03a0_coll-min (Fig. 8, paper \\u00a7VIII.B).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/FrostVerifier.sol\":\"TLSAttestation\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"],\"viaIR\":true},\"sources\":{\"src/FrostVerifier.sol\":{\"keccak256\":\"0x725b6dee030e7b3025a0d0a826e2ab845dd543746c0a86528afb60e9bfc0ad63