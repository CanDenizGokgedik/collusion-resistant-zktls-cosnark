;;;;;;;6379:93;;;:::i;:::-;1290:5448;;;;;;:::i;:::-;;;;;;;;;;;;;6527:155;;;;;;6708:15;;;:::i;:::-;1386:66;;;;5733:50;;5408:513;5861:15;;;:22;5857:58;;5408:513::o;5857:58::-;5543:15;;-1:-1:-1;5408:513:19:o;5733:50::-;5767:5;;;;:::i;:::-;5733:50;;;1290:5448;;;;;;;;;;;;;;;:::o;:::-;;;;;;;;;;;:::o","linkReferences":{}},"methodIdentifiers":{"verify(bytes32,uint256,uint256,uint256,uint256)":"a1f31281"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.24+commit.e11b9ed9\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"message_hash\",\"type\":\"bytes32\"},{\"internalType\":\"uint256\",\"name\":\"pk_x\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"pk_y\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sig_R_x\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"sig_s\",\"type\":\"uint256\"}],\"name\":\"verify\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"custom:changes\":\"- _modExp: fixed staticcall output buffer (was writing to stack slot, now uses memory).   - _verifyWithPrecompiles: added y-parity check to enforce even-y convention.   - _ecMul/_ecAdd: replaced hardcoded gas (pre-EIP-2929) with gas() forwarding.\",\"custom:security-properties\":\"- Aggregate signature \\u03c3 = (R, s) proves \\u2265 t aux verifiers signed.   - Forgery requires breaking discrete-log on secp256k1 (DLOG assumption).   - The message digest commits to the full attestation (statement, rand, session).\",\"details\":\"Implements SC.Verify(\\u03c3, pk) from \\u03a0_coll-min (Fig. 8, paper \\u00a7VIII.B). Paper reference (Table I, \\u00a7IX):   FROST on secp256k1: 2 ECMUL + 2 ECADD + 1 Hash-to-G \\u2192 ~4,200 gas on secp256k1. Signature format (65 bytes):   bytes  0\\u201332: R.x  (x-coordinate of nonce commitment R = k*G)   bytes 32\\u201364: s    (scalar: s = k + e*sk, where e = H(R||PK||msg)) Verification equation (BIP-340 / FROST Schnorr):   e = keccak256(abi.encodePacked(R_x, pk_x, message_hash)) mod n   Check: s*G = R + e*PK  with R having even y-coordinate.\",\"kind\":\"dev\",\"methods\":{\"verify(bytes32,uint256,uint256,uint256,uint256)\":{\"params\":{\"message_hash\":\"32-byte digest that was signed (envelope_digest).\",\"pk_x\":\"x-coordinate of the group verifying key.\",\"pk_y\":\"y-coordinate of the group verifying key.\",\"sig_R_x\":\"x-coordinate of the nonce commitment R (even-y convention).\",\"sig_s\":\"Schnorr scalar s.\"},\"returns\":{\"valid\":\"       true iff the signature is valid.\"}}},\"title\":\"FrostVerifier\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"verify(bytes32,uint256,uint256,uint256,uint256)\":{\"notice\":\"Verify a FROST Schnorr aggregate signature.\"}},\"notice\":\"On-chain verifier for FROST(secp256k1) threshold Schnorr signatures.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/FrostVerifier.sol\":\"FrostVerifier\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"],\"viaIR\":true},\"sources\":{\"src/FrostVerifier.sol\":{\"keccak256\":\"0x725b6dee030e7b3025a0d0a826e2ab845dd543746c0a86528afb60e9bfc0ad63\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://c7dd7743f3e8d44bf1bdae908e498c6dae25f3768cb360f4e2d37da4c725bf88\",\"dweb:/ipfs/QmTJZ8kcHnzenJocPftEWKzFsr3P5q3ftqhhRqBibKzPNc\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.24+commit.e11b9ed9"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"bytes32","name":"message_hash","type":"bytes32"},{"internalType":"uint256","name":"pk_x","type":"uint256"},{"internalType":"uint256","name":"pk_y","type":"uint256"},{"internalType":"uint256","name":"sig_R_x","type":"uint256"},{"internalType":"uint256","name":"sig_s","type":"uint256"}],"stateMutability":"view","type":"function","name":"verify","outputs":[{"internalType":"bool","name":"valid","type":"bool"}]}],"devdoc":{"kind":"dev","methods":{"verify(bytes32,uint256,uint256,uint256,uint256)":{"params":{"message_hash":"32-byte digest that was signed (envelope_digest).","pk_x":"x-coordinate of the group verifying key.","pk_y":"y-coordinate of the group verifying key.","sig_R_x":"x-coordinate of the nonce commitment R (even-y convention).","sig_s":"Schnorr scalar s."},"returns":{"valid":"       true iff the signature is valid."}}},"version":1},"userdoc":{"kind":"user","methods":{"verify(bytes32,uint256,uint256,uint256,uint256)":{"notice":"Verify a FROST Schnorr aggregate signature."}},"version":1}},"settings":{"remappings":["forge-std/=lib/forge-std/src/"],"optimizer":{"enabled":true,"runs":200},"metadata":{"bytecodeHash":"ipfs"},"compilationTarget":{"src/FrostVerifier.sol":"FrostVerifier"},"evmVersion":"cancun","libraries":{},"viaIR":true},"sources":{"src/FrostVerifier.sol":{"keccak256":"0x725b6dee030e7b3025a0d0a826e2ab845dd543746c0a86528afb60e9bfc0ad63","urls":["bzz-raw://c7dd7743f3e8d44bf1bdae908e498c6dae25f3768cb360f4e2d37da4c725bf88","dweb:/ipfs/QmTJZ8kcHnzenJocPftEWKzFsr3P5q3ftqhhRqBibKzPNc"],"license":"MIT"}},"version":1},"id":19}